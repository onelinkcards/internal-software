# Supabase (browser: anon key only). Create project → Settings → API.
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Production: one public domain for short links (where /i/... is served — your billing SPA).
# Example if billing is at https://www.onelink.cards/billing:
#   VITE_PUBLIC_INVOICE_HOST=https://www.onelink.cards/billing
VITE_PUBLIC_INVOICE_HOST=

# Next.js site origin that exposes GET /api/invoice-share/public (usually same apex as marketing site).
# Example: https://www.onelink.cards
VITE_INVOICE_SHARE_PUBLIC_BASE=

# POST URL on the Next.js app (server writes to Supabase with service role).
# Example: https://www.onelink.cards/api/invoice-share
VITE_INVOICE_SYNC_URL=

# Same value as ONELINK_INVOICE_SYNC_SECRET on the Next server (never commit the real value).
VITE_ONELINK_INVOICE_SECRET=
